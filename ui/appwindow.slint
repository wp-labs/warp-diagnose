import {
    DetailRow,
    LaneLabel,
    TimeTick,
    TimelinePoint
} from "base_components.slint";
import { AppShell } from "app_shell.slint";
import { AlertDataPage, LogDataPage, OverviewPage } from "pages.slint";

export component AppWindow inherits Window {
    out property <length> logical_window_height: self.height;
    min-width: 1500px;
    min-height: 920px;
    in-out property <string> status_text: "Ready";
    in-out property <int> total_events: 0;
    in-out property <int> risk_low_events: 0;
    in-out property <int> risk_mid_events: 0;
    in-out property <int> risk_high_events: 0;

    in-out property <string> top_targets_text: "No data loaded";
    in-out property <string> source_text: "No data loaded";

    in-out property <string> point_detail_summary: "Click any point to inspect input logs.";
    in-out property <[DetailRow]> point_detail_rows: [];
    in-out property <string> lane_legend_text: "No lane";
    in-out property <string> hover_detail_text: "Hover a point to preview.";
    in-out property <int> hovered_timeline_point_index: -1;
    in-out property <int> selected_timeline_point_index: -1;

    in-out property <[TimelinePoint]> timeline_points: [];
    in-out property <[TimeTick]> time_ticks: [];
    in-out property <float> first_event_x_pct: 0.0;
    in-out property <float> last_event_x_pct: 1.0;
    in-out property <int> timeline_content_px: 1400;
    in-out property <length> timeline_canvas_x: -600px;
    in-out property <float> timeline_zoom: 1.0;
    in-out property <int> active_level_filter: 0;
    in-out property <int> active_risk_filter: 0;
    in-out property <int> active_source_filter: 0;
    in-out property <bool> has_level_filter: false;
    in-out property <bool> has_risk_filter: false;
    in-out property <bool> has_source_filter: false;
    in-out property <string> active_level_filter_text: "All levels";
    in-out property <string> active_risk_filter_text: "All risks";
    in-out property <string> active_source_filter_text: "All sources";
    in-out property <[LaneLabel]> lane_labels: [];
    in-out property <string> filtered_log_summary: "No log data loaded.";
    in-out property <[DetailRow]> filtered_log_rows: [];
    in-out property <string> log_page_text: "Page 1/1 · 0 rows";
    in-out property <bool> has_prev_log_page: false;
    in-out property <bool> has_next_log_page: false;
    in-out property <length> log_table_body_viewport_height: 0px;
    in-out property <int> log_table_reset_token: 0;
    in-out property <string> filtered_alert_summary: "No alert data loaded.";
    in-out property <[DetailRow]> filtered_alert_rows: [];
    in-out property <string> alert_page_text: "Page 1/1 · 0 rows";
    in-out property <bool> has_prev_alert_page: false;
    in-out property <bool> has_next_alert_page: false;
    in-out property <length> alert_table_body_viewport_height: 0px;
    in-out property <int> alert_table_reset_token: 0;
    in-out property <int> active_page: 0;

    callback reload_data();
    callback page_changed(int);
    callback level_filter_clicked(int);
    callback risk_filter_clicked(int);
    callback source_filter_clicked(int);
    callback clear_level_filter();
    callback clear_risk_filter();
    callback clear_source_filter();
    callback clear_all_filters();
    callback point_clicked(int);
    callback point_hovered(int);
    callback point_unhovered();
    callback log_prev_page();
    callback log_next_page();
    callback alert_prev_page();
    callback alert_next_page();
    callback window_resized();
    title: "Warp Diagnose";
    no-frame: false;
    background: #eef3f8;
    changed width => {
        root.window_resized();
    }
    changed height => {
        root.window_resized();
    }
    changed log_table_body_viewport_height => {
        if (root.active_page == 1) {
            root.window_resized();
        }
    }
    changed alert_table_body_viewport_height => {
        if (root.active_page == 2) {
            root.window_resized();
        }
    }

    VerticalLayout {
        spacing: 10px;
        padding: 12px;

        AppShell {
            total-events: root.total_events;
            risk-low-events: root.risk_low_events;
            risk-mid-events: root.risk_mid_events;
            risk-high-events: root.risk_high_events;
            active-level-filter: root.active_level_filter;
            active-risk-filter: root.active_risk_filter;
            active-source-filter: root.active_source_filter;
            has-level-filter: root.has_level_filter;
            has-risk-filter: root.has_risk_filter;
            has-source-filter: root.has_source_filter;
            active-level-filter-text: root.active_level_filter_text;
            active-risk-filter-text: root.active_risk_filter_text;
            active-source-filter-text: root.active_source_filter_text;
            active-page: root.active_page;
            reload-data => { root.reload_data(); }
            page-changed(idx) => { root.page_changed(idx); }
            level-filter-clicked(idx) => { root.level_filter_clicked(idx); }
            risk-filter-clicked(idx) => { root.risk_filter_clicked(idx); }
            source-filter-clicked(idx) => { root.source_filter_clicked(idx); }
            clear-level-filter => { root.clear_level_filter(); }
            clear-risk-filter => { root.clear_risk_filter(); }
            clear-source-filter => { root.clear_source_filter(); }
            clear-all-filters => { root.clear_all_filters(); }
        }

        if (root.active_page == 0) : OverviewPage {
            vertical-stretch: 1;
            lane-labels: root.lane_labels;
            timeline-points: root.timeline_points;
            time-ticks: root.time_ticks;
            first-event-x-pct: root.first_event_x_pct;
            last-event-x-pct: root.last_event_x_pct;
            timeline-content-px: root.timeline_content_px;
            timeline-canvas-x <=> root.timeline_canvas_x;
            timeline-zoom <=> root.timeline_zoom;
            hover-detail-text: root.hover_detail_text;
            hovered-point-index: root.hovered_timeline_point_index;
            selected-point-index: root.selected_timeline_point_index;
            point-detail-summary: root.point_detail_summary;
            point-detail-rows: root.point_detail_rows;
            lane-legend-text: root.lane_legend_text;
            top-targets-text: root.top_targets_text;
            source-text: root.source_text;
            status-text: root.status_text;
            clear-all-filters => {
                root.clear_all_filters();
            }
            point-clicked(idx) => {
                root.point_clicked(idx);
            }
            point-hovered(idx) => {
                root.point_hovered(idx);
            }
            point-unhovered => {
                root.point_unhovered();
            }
        }

        if (root.active_page == 1) : LogDataPage {
            vertical-stretch: 1;
            summary: root.filtered_log_summary;
            rows: root.filtered_log_rows;
            pagination-text: root.log_page_text;
            has-prev-page: root.has_prev_log_page;
            has-next-page: root.has_next_log_page;
            reset-token: root.log_table_reset_token;
            changed table-body-visible-height => {
                root.log_table_body_viewport_height = self.table-body-visible-height;
            }
            prev-page => {
                root.log_prev_page();
            }
            next-page => {
                root.log_next_page();
            }
        }

        if (root.active_page == 2) : AlertDataPage {
            vertical-stretch: 1;
            summary: root.filtered_alert_summary;
            rows: root.filtered_alert_rows;
            pagination-text: root.alert_page_text;
            has-prev-page: root.has_prev_alert_page;
            has-next-page: root.has_next_alert_page;
            reset-token: root.alert_table_reset_token;
            changed table-body-visible-height => {
                root.alert_table_body_viewport_height = self.table-body-visible-height;
            }
            prev-page => {
                root.alert_prev_page();
            }
            next-page => {
                root.alert_next_page();
            }
        }
    }
}
