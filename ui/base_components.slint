}

export component ViewSegmentButton inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    callback clicked;

    min-width: 132px;
    height: 36px;
    border-radius: 18px;
    background: selected ? #ffffff : transparent;
    border-width: selected ? 1px : 0px;
    border-color: selected ? #8db2ea : transparent;

    Text {
        text: label;
        color: selected ? #0f56c9 : #49627f;
        font-size: 12px;
        font-weight: selected ? 700 : 650;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component TableHeaderCell inherits Rectangle {
    in property <string> text;
    in-out property <length> col-width: 100px;
    in property <color> text-color: #24384d;
    in property <length> min-col-width: 48px;
    in property <bool> resizable: true;
    callback width-changed(length);

    width: col-width;
    background: transparent;

    Text {
        text: root.text;
        x: 0px;
        y: 0px;
        width: parent.width - (root.resizable ? 8px : 0px);
        height: parent.height;
        color: root.text-color;
        font-size: 12px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    Rectangle {
        visible: root.resizable;
        x: parent.width - 1px;
        y: 7px;
        width: 1px;
        height: parent.height - 14px;
        background: #c8d7e8;
    }

    resize-handle := TouchArea {
        enabled: root.resizable;
        mouse-cursor: ew-resize;
        property <length> start-width: 0px;

        x: parent.width - 6px;
        y: 0px;
        width: 12px;
        height: parent.height;

        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                self.start-width = root.col-width;
            }
        }

        moved => {
            if (self.enabled && self.pressed) {
                let next-width = max(root.min-col-width, self.start-width + (self.mouse-x - self.pressed-x));
                root.col-width = next-width;
                root.width-changed(next-width);
            }
        }
    }
}

export component TableBodyCell inherits Rectangle {
    in property <string> text;
    in property <length> col-width: 100px;
    in property <color> text-color: #334155;
    in property <TextHorizontalAlignment> align: center;
    in property <bool> elide: false;

    width: col-width;
    background: transparent;

    Text {
        text: root.text;
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        color: root.text-color;
        font-size: 12px;
        vertical-alignment: center;
        horizontal-alignment: root.align;
        overflow: root.elide ? TextOverflow.elide : TextOverflow.clip;
    }
}

export component DataGridFrame inherits Rectangle {
    in property <string> title;
    in property <string> summary: "";
    in property <bool> show-summary: true;
    in property <[DetailRow]> rows: [];
    in property <string> time-title: "Time";
    in property <string> level-title: "Level";
    in property <bool> show-event-count: false;
    in property <string> event-count-title: "EventCount";
    in property <bool> show-rule: false;
    in property <string> rule-title: "Rule";
    in property <string> target-title: "Target";
    in property <string> content-title: "Content";
    in property <string> status-title: "Status";
    in property <bool> show-status: true;
    in property <bool> show-content: true;
    in property <bool> show-risk-score: false;
    in property <bool> semantic-alert-layout: false;
    in property <bool> compact-when-empty: false;
    in property <length> table-width: 900px;
    in property <length> body-viewport-height: 252px;
    in property <bool> show-pagination: false;
    in property <bool> has-prev-page: false;
    in property <bool> has-next-page: false;
    in property <string> pagination-text: "";
    in property <int> reset-token: 0;
    callback prev-page();
    callback next-page();
    out property <length> body-visible-height:
        max(compact-when-empty && rows.length == 0 ? 56px : 120px, table-shell.height - root.header-height - 6px);
    private property <length> header-height: 30px;
    private property <length> row-height: 30px;
    private property <length> body-height: max(root.body-visible-height, rows.length * root.row-height);
    private property <length> col-gap: 8px;
    private property <length> col-row-no-width: 44px;
    private property <length> col-time-width: 150px;
    private property <length> col-level-width: 74px;
    private property <length> col-event-count-width: 86px;
    private property <length> col-risk-width: 76px;
    private property <length> col-rule-width: 128px;
    private property <length> col-target-width: 96px;
    private property <length> col-entity-width: 120px;
    private property <length> col-action-width: 88px;
    private property <length> col-status-width: 76px;
    private property <length> col-content-width: 360px;
    private property <length> computed-table-width:
        20px
        + col-row-no-width
        + col-gap + col-time-width
        + col-gap + col-level-width
        + (show-event-count ? col-gap + col-event-count-width : 0px)
        + (show-risk-score ? col-gap + col-risk-width : 0px)
        + (show-rule ? col-gap + col-rule-width : 0px)
        + col-gap + col-target-width
        + col-gap + col-entity-width
        + col-gap + col-action-width
        + (show-status ? col-gap + col-status-width : 0px)
        + (show-content ? col-gap + col-content-width : 0px);

    border-radius: 10px;
    background: #ffffff;
    border-width: 1px;
    border-color: #dde5ee;
    min-height: compact-when-empty && rows.length == 0 ? 110px : 220px;
    changed rows => {
        table-scroll.viewport-x = 0px;
    }
    changed reset-token => {
        table-scroll.viewport-x = 0px;
    }

    VerticalLayout {
        padding: 10px;
        spacing: 4px;

        Text {
            text: title;
            color: #31445d;
            font-size: 13px;
            font-weight: 600;
            horizontal-alignment: left;
        }

        if (show-summary && summary != "") : Text {
            text: summary;
            color: #64748b;
            font-size: 11px;
            horizontal-alignment: left;
        }

        if (show-pagination) : HorizontalLayout {
            spacing: 8px;

            Text {
                text: pagination-text;
                color: #51657c;
                font-size: 11px;
                vertical-alignment: center;
            }

            Rectangle { background: transparent; }

            Button {
                text: "Prev";
                enabled: has-prev-page;
                clicked => {
                    root.prev-page();
                }
            }

            Button {
                text: "Next";
                enabled: has-next-page;
                clicked => {
                    root.next-page();
                }
            }
        }

        table-shell := Rectangle {
            vertical-stretch: 1;
            clip: true;
            table-scroll := ScrollView {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                viewport-y: 0px;
                vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

                Rectangle {
                    width: max(max(table-width, root.computed-table-width), table-scroll.visible-width);
                    height: parent.height;

                    Rectangle {
                        x: 0px;
                        y: 0px;
                        width: parent.width;
                        height: root.header-height;
                        border-radius: 8px;
                        background: #e9eff6;
                        border-width: 1px;
                        border-color: #dfe7f0;

                        if (!semantic-alert-layout) : HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: root.col-gap;

                            TableHeaderCell { text: "#"; col-width <=> root.col-row-no-width; min-col-width: 36px; }
                            TableHeaderCell { text: time-title; col-width <=> root.col-time-width; min-col-width: 120px; }
                            TableHeaderCell { text: level-title; col-width <=> root.col-level-width; min-col-width: 64px; }
                            if (show-event-count) : TableHeaderCell { text: event-count-title; col-width <=> root.col-event-count-width; min-col-width: 72px; }
                            if (show-risk-score) : TableHeaderCell { text: "RiskScore"; col-width <=> root.col-risk-width; min-col-width: 68px; }
                            if (show-rule) : TableHeaderCell { text: rule-title; col-width <=> root.col-rule-width; min-col-width: 96px; }
                            TableHeaderCell { text: target-title; col-width <=> root.col-target-width; min-col-width: 80px; }
                            TableHeaderCell { text: "Entity"; col-width <=> root.col-entity-width; min-col-width: 88px; }
                            TableHeaderCell { text: "Action"; col-width <=> root.col-action-width; min-col-width: 76px; }
                            if (show-status) : TableHeaderCell { text: status-title; col-width <=> root.col-status-width; min-col-width: 68px; }
                            if (show-content) : TableHeaderCell { text: content-title; col-width <=> root.col-content-width; min-col-width: 140px; }
                        }

                        if (semantic-alert-layout) : HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: root.col-gap;

                            TableHeaderCell { text: "#"; col-width <=> root.col-row-no-width; min-col-width: 36px; text-color: #1f5fd6; }
                            TableHeaderCell { text: time-title; col-width <=> root.col-time-width; min-col-width: 120px; text-color: #1f5fd6; }
                            TableHeaderCell { text: level-title; col-width <=> root.col-level-width; min-col-width: 64px; text-color: #1f5fd6; }
                            if (show-event-count) : TableHeaderCell { text: event-count-title; col-width <=> root.col-event-count-width; min-col-width: 72px; text-color: #1f5fd6; }
                            if (show-risk-score) : TableHeaderCell { text: "RiskScore"; col-width <=> root.col-risk-width; min-col-width: 68px; text-color: #1f5fd6; }
                            if (show-rule) : TableHeaderCell { text: rule-title; col-width <=> root.col-rule-width; min-col-width: 96px; text-color: #1f5fd6; }
                            TableHeaderCell { text: "Entity"; col-width <=> root.col-entity-width; min-col-width: 88px; text-color: #1f5fd6; }
                            TableHeaderCell { text: target-title; col-width <=> root.col-target-width; min-col-width: 80px; text-color: #23734f; }
                            TableHeaderCell { text: "Action"; col-width <=> root.col-action-width; min-col-width: 76px; text-color: #9b5f00; }
                            if (show-status) : TableHeaderCell { text: status-title; col-width <=> root.col-status-width; min-col-width: 68px; text-color: #b54752; }
                            if (show-content) : TableHeaderCell { text: content-title; col-width <=> root.col-content-width; min-col-width: 140px; text-color: #35506e; }
                        }
                    }

                    Rectangle {
                        x: 0px;
                        y: root.header-height + 6px;
                        width: parent.width;
                        height: max(0px, parent.height - root.header-height - 6px);
                        border-radius: 8px;
                        background: #f8fafc;
                        border-width: 1px;
                        border-color: #e3eaf2;
                        clip: true;

                        for row[i] in rows: Rectangle {
                            private property <color> risk-tier-color: row.risk_tier >= 9 ? #991b1b
                                : (row.risk_tier == 8 ? #dc2626
                                : (row.risk_tier == 7 ? #c2410c
                                : (row.risk_tier == 6 ? #d97706
                                : (row.risk_tier == 5 ? #c99700
                                : (row.risk_tier == 4 ? #a3a300
                                : (row.risk_tier == 3 ? #6f9a2b
                                : (row.risk_tier == 2 ? #5f8f57
                                : (row.risk_tier == 1 ? #6d8f84 : #7f9b91))))))));
                            x: 0px;
                            y: i * root.row-height;
                            width: parent.width;
                            height: root.row-height;
                            background: Math.mod(i, 2) == 0 ? #fafcff : #f6f9fc;

                            if (!semantic-alert-layout) : HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: root.col-gap;

                                TableBodyCell { text: row.row_no; col-width: root.col-row-no-width; text-color: #334155; align: center; }
                                TableBodyCell { text: row.time; col-width: root.col-time-width; text-color: #334155; align: left; }
                                TableBodyCell {
                                    text: row.level;
                                    col-width: root.col-level-width;
                                    text-color: row.risk_tier >= 9 ? #991b1b
                                        : (row.risk_tier == 8 ? #dc2626
                                        : (row.risk_tier == 7 ? #c2410c
                                        : (row.risk_tier == 6 ? #d97706
                                        : (row.risk_tier == 5 ? #c99700
                                        : (row.risk_tier == 4 ? #a3a300
                                        : (row.risk_tier == 3 ? #6f9a2b
                                        : (row.risk_tier == 2 ? #5f8f57
                                        : (row.risk_tier == 1 ? #6d8f84 : #7f9b91))))))));
                                    align: left;
                                }
                                if (show-event-count) : TableBodyCell { text: row.event_count; col-width: root.col-event-count-width; text-color: #334155; align: center; }
                                if (show-risk-score) : TableBodyCell {
                                    text: row.risk_score;
                                    col-width: root.col-risk-width;
                                    text-color: row.risk_tier >= 9 ? #991b1b
                                        : (row.risk_tier == 8 ? #dc2626
                                        : (row.risk_tier == 7 ? #c2410c
                                        : (row.risk_tier == 6 ? #d97706
                                        : (row.risk_tier == 5 ? #c99700
                                        : (row.risk_tier == 4 ? #a3a300
                                        : (row.risk_tier == 3 ? #6f9a2b
                                        : (row.risk_tier == 2 ? #5f8f57
                                        : (row.risk_tier == 1 ? #6d8f84 : #7f9b91))))))));
                                    align: center;
                                }
                                if (show-rule) : TableBodyCell { text: row.rule; col-width: root.col-rule-width; text-color: #334155; align: left; }
                                TableBodyCell { text: row.target; col-width: root.col-target-width; text-color: #334155; align: left; }
                                TableBodyCell { text: row.entity; col-width: root.col-entity-width; text-color: #334155; align: left; }
                                TableBodyCell { text: row.action; col-width: root.col-action-width; text-color: #334155; align: left; }
                                if (show-status) : TableBodyCell { text: row.status; col-width: root.col-status-width; text-color: #334155; align: left; }
                                if (show-content) : TableBodyCell { text: row.content; col-width: root.col-content-width; text-color: #334155; align: left; elide: true; }
                            }

                            if (semantic-alert-layout) : HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: root.col-gap;

                                TableBodyCell { text: row.row_no; col-width: root.col-row-no-width; text-color: #294b75; align: center; }
                                TableBodyCell { text: row.time; col-width: root.col-time-width; text-color: #294b75; align: left; }
                                TableBodyCell {
                                    text: row.level;
                                    col-width: root.col-level-width;
                                    text-color: row.risk_tier >= 9 ? #991b1b
                                        : (row.risk_tier == 8 ? #dc2626
                                        : (row.risk_tier == 7 ? #c2410c
                                        : (row.risk_tier == 6 ? #d97706
                                        : (row.risk_tier == 5 ? #c99700
                                        : (row.risk_tier == 4 ? #a3a300
                                        : (row.risk_tier == 3 ? #6f9a2b
                                        : (row.risk_tier == 2 ? #5f8f57
                                        : (row.risk_tier == 1 ? #6d8f84 : #7f9b91))))))));
                                    align: left;
                                }
                                if (show-event-count) : TableBodyCell { text: row.event_count; col-width: root.col-event-count-width; text-color: #294b75; align: center; }
                                if (show-risk-score) : TableBodyCell {
                                    text: row.risk_score;
                                    col-width: root.col-risk-width;
                                    text-color: row.risk_tier >= 9 ? #b91c1c
                                        : (row.risk_tier == 8 ? #d9480f
                                        : (row.risk_tier == 7 ? #ea580c
                                        : (row.risk_tier == 6 ? #ca8a04
                                        : (row.risk_tier == 5 ? #65a30d
                                        : (row.risk_tier == 4 ? #16a34a
                                        : (row.risk_tier == 3 ? #0f766e
                                        : (row.risk_tier == 2 ? #0891b2
                                        : (row.risk_tier == 1 ? #2563eb : #4f46e5))))))));
                                    align: center;
                                }
                                if (show-rule) : TableBodyCell { text: row.rule; col-width: root.col-rule-width; text-color: #294b75; align: left; }
                                TableBodyCell { text: row.entity; col-width: root.col-entity-width; text-color: #294b75; align: left; }
                                TableBodyCell { text: row.target; col-width: root.col-target-width; text-color: #2e6b53; align: left; }
                                TableBodyCell { text: row.action; col-width: root.col-action-width; text-color: #8a5a12; align: left; }
                                if (show-status) : TableBodyCell { text: row.status; col-width: root.col-status-width; text-color: #a23a44; align: left; }
                                if (show-content) : TableBodyCell { text: row.content; col-width: root.col-content-width; text-color: #425f7d; align: left; elide: true; }
                            }
                        }
                    }
                }
            }
        }
    }
}

export component LogTableView inherits DataGridFrame {
    vertical-stretch: 1;
    title: "Filtered Log Data";
    show-summary: false;
    show-risk-score: true;
    table-width: 1280px;
    body-viewport-height: 652px;
    show-pagination: true;
}

export component AlertTableView inherits DataGridFrame {
    vertical-stretch: 1;
    title: "Filtered Alert Data";
    show-summary: false;
    time-title: "FiredAt";
    level-title: "RiskLevel";
    show-event-count: true;
    show-rule: true;
    rule-title: "Rule";
    target-title: "Target";
    show-status: false;
    show-content: false;
    content-title: "Message";
    show-risk-score: true;
    semantic-alert-layout: true;
    table-width: 1420px;
    body-viewport-height: 652px;
    show-pagination: true;
}
