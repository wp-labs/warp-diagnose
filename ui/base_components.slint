import { Button, ScrollView } from "std-widgets.slint";

export struct TimelinePoint {
    x_pct: float,
    y_pct: float,
    risk: float,
    risk_tier: int,
    size_norm: float,
    entity: string,
}

export struct TimeTick {
    x_pct: float,
    label: string,
}

export struct LaneLabel {
    y_pct: float,
    label: string,
}

export struct DetailRow {
    row_no: string,
    time: string,
    level: string,
    risk_tier: int,
    event_count: string,
    risk_score: string,
    rule: string,
    target: string,
    entity: string,
    action: string,
    status: string,
    content: string,
}

export component AppLogo inherits Rectangle {
    border-radius: 12px;
    background: #ffffff;
    border-width: 1px;
    border-color: #c7d5e6;

    Rectangle {
        x: 6px;
        y: 6px;
        width: parent.width - 12px;
        height: parent.height - 12px;
        border-radius: 9px;
        background: #edf4ff;
    }

    Rectangle {
        x: 10px;
        y: parent.height / 2;
        width: parent.width - 20px;
        height: 2px;
        background: #95a9c3;
    }

    Rectangle {
        x: 12px;
        y: 14px;
        width: parent.width - 24px;
        height: 2px;
        background: #c2d3e8;
    }

    Rectangle {
        x: 12px;
        y: parent.height - 16px;
        width: parent.width - 24px;
        height: 2px;
        background: #c2d3e8;
    }

    Rectangle {
        x: 11px;
        y: parent.height / 2 - 7px;
        width: 10px;
        height: 10px;
        border-radius: 5px;
        background: #35b883;
    }

    Rectangle {
        x: parent.width / 2 - 5px;
        y: 10px;
        width: 10px;
        height: 10px;
        border-radius: 5px;
        background: #d9a23b;
    }

    Rectangle {
        x: parent.width - 21px;
        y: parent.height / 2 - 11px;
        width: 10px;
        height: 10px;
        border-radius: 5px;
        background: #e66a73;
    }

    Rectangle {
        x: 16px;
        y: parent.height / 2 - 2px;
        width: 8px;
        height: 2px;
        background: #5b8def;
    }

    Rectangle {
        x: 24px;
        y: parent.height / 2 - 6px;
        width: 7px;
        height: 2px;
        background: #5b8def;
    }

    Rectangle {
        x: 31px;
        y: parent.height / 2 - 10px;
        width: 7px;
        height: 2px;
        background: #5b8def;
    }

    Rectangle {
        x: 38px;
        y: parent.height / 2 - 8px;
        width: 7px;
        height: 2px;
        background: #5b8def;
    }

    Rectangle {
        x: 45px;
        y: parent.height / 2 - 4px;
        width: 7px;
        height: 2px;
        background: #5b8def;
    }
}

export component MetricCard inherits Rectangle {
    in property <string> label;
    in property <int> value;
    in property <color> tone: #dce8f8;
    in property <bool> selected: false;
    in property <bool> interactive: false;
    callback clicked;

    border-radius: 10px;
    background: tone;
    height: 82px;
    border-width: selected ? 2px : 1px;
    border-color: selected ? #2f6fed : #c7d5e6;

    VerticalLayout {
        padding: 10px;
        spacing: 4px;

        Text {
            text: label;
            color: #5c6d82;
            font-size: 12px;
            horizontal-alignment: left;
        }

        Text {
            text: value;
            color: #132238;
            font-size: 22px;
            font-weight: 700;
            horizontal-alignment: left;
        }
    }

    TouchArea {
        enabled: interactive;
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component FilterPill inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    in property <length> min-chip-width: 56px;
    in property <float> width-scale: 1.4;
    in property <color> idle-background: #f6f8fb;
    in property <color> idle-border: #d7e0ea;
    in property <color> idle-text: #4f6279;
    in property <color> selected-background: #e7f0ff;
    in property <color> selected-border: #8eb2ef;
    in property <color> selected-text: #1f5fd6;
    callback clicked;

    private property <length> chip-width: max(min-chip-width, (label-text.min-width + 16px) * width-scale);
    min-width: chip-width;
    preferred-width: chip-width;
    max-width: chip-width;
    horizontal-stretch: 0;
    height: 24px;
    border-radius: 12px;
    background: selected ? selected-background : idle-background;
    border-width: 1px;
    border-color: selected ? selected-border : idle-border;

    label-text := Text {
        text: label;
        color: selected ? selected-text : idle-text;
        font-size: 11px;
        font-weight: selected ? 700 : 600;
        horizontal-alignment: center;
        vertical-alignment: center;
        x: 8px;
        width: parent.width - 16px;
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component ActiveFilterChip inherits Rectangle {
    in property <string> label;
    in property <color> chip-background-color: #f4f7fb;
    in property <color> chip-border-color: #d8e1eb;
    in property <color> chip-text-color: #51657c;
    callback clicked;

    private property <length> chip-width: max(66px, chip-text.min-width + 24px);
    min-width: chip-width;
    preferred-width: chip-width;
    max-width: chip-width;
    horizontal-stretch: 0;
    height: 24px;
    border-radius: 12px;
    background: chip-background-color;
    border-width: 1px;
    border-color: chip-border-color;

    chip-text := Text {
        text: label;
        color: chip-text-color;
        font-size: 11px;
        font-weight: 600;
        x: 12px;
        width: parent.width - 24px;
        vertical-alignment: center;
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component ScrollTextPanel inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <length> body-size: 12px;
    in property <length> body-viewport-height: 120px;

    border-radius: 10px;
    background: #ffffff;

    VerticalLayout {
        padding: 10px;
        spacing: 6px;

        Text {
            text: title;
            color: #203047;
            font-size: 13px;
            font-weight: 700;
            horizontal-alignment: left;
        }

        body-scroll := ScrollView {
            vertical-stretch: 1;
            vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
            horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;

            Rectangle {
                width: parent.width - 6px;
                height: max(body-viewport-height, body-scroll.height);
                background: #f6f9fc;
                border-radius: 8px;
                border-width: 1px;
                border-color: #d8e3ee;

                Text {
                    text: body;
                    color: #334155;
                    x: 10px;
                    y: 8px;
                    width: parent.width - 20px;
                    font-family: "Menlo";
                    font-size: body-size;
                    wrap: word-wrap;
                    horizontal-alignment: left;
                    vertical-alignment: top;
                }
            }
        }
    }
}

