import {
    ActiveFilterChip,
    AppLogo,
    FilterPill,
    InlineIconButton,
    ViewSegmentButton,
    TimelineToolButton
} from "base_components.slint";

export component AppShell inherits Rectangle {
    in property <int> total-events: 0;
    in property <int> risk-low-events: 0;
    in property <int> risk-mid-events: 0;
    in property <int> risk-high-events: 0;
    in property <int> active-level-filter: 0;
    in property <int> active-risk-filter: 0;
    in property <int> active-source-filter: 0;
    in property <bool> has-level-filter: false;
    in property <bool> has-risk-filter: false;
    in property <bool> has-source-filter: false;
    in property <string> active-level-filter-text: "All levels";
    in property <string> active-risk-filter-text: "All risks";
    in property <string> active-source-filter-text: "All sources";
    in property <int> active-page: 0;
    callback reload-data();
    callback page-changed(int);
    callback level-filter-clicked(int);
    callback risk-filter-clicked(int);
    callback source-filter-clicked(int);
    callback clear-level-filter();
    callback clear-risk-filter();
    callback clear-source-filter();
    callback clear-all-filters();

    VerticalLayout {
        spacing: 8px;

        Rectangle {
            height: 44px;
            border-radius: 10px;
            background: #ffffff;
            border-width: 1px;
            border-color: #d6e0ea;

            HorizontalLayout {
                padding: 6px;
                spacing: 10px;

                AppLogo {
                    width: 30px;
                    height: 30px;
                }

                Text {
                    text: "Warp Diagnose";
                    color: #203047;
                    font-size: 16px;
                    font-weight: 700;
                    vertical-alignment: center;
                }

                Rectangle {
                    background: transparent;
                }

                TimelineToolButton {
                    tool-icon: @image-url("icons/reload.svg");
                    clicked => {
                        root.reload-data();
                    }
                }
            }
        }

        Rectangle {
            height: 108px;
            border-radius: 10px;
            background: #ffffff;
            border-width: 1px;
            border-color: #d6e0ea;

            VerticalLayout {
                padding: 8px;
                spacing: 6px;

                HorizontalLayout {
                    spacing: 10px;

                    Rectangle {
                        min-width: 460px;
                        preferred-width: 520px;
                        horizontal-stretch: 3;
                        height: 42px;
                        background: transparent;

                        HorizontalLayout {
                            spacing: 12px;

                            Rectangle {
                                width: 56px;
                                height: parent.height;
                                background: transparent;

                                Text {
                                    text: "View";
                                    color: #667d96;
                                    font-size: 12px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                height: 42px;
                                horizontal-stretch: 1;
                                border-radius: 18px;
                                background: #ecf2f8;
                                border-width: 1px;
                                border-color: #d5e0ec;

                                HorizontalLayout {
                                    padding: 4px;
                                    spacing: 4px;

                                    ViewSegmentButton {
                                        label: "Overview";
                                        selected: root.active-page == 0;
                                        clicked => { root.page-changed(0); }
                                    }

                                    ViewSegmentButton {
                                        label: "Log Data";
                                        selected: root.active-page == 1;
                                        clicked => { root.page-changed(1); }
                                    }

                                    ViewSegmentButton {
                                        label: "Alert Data";
                                        selected: root.active-page == 2;
                                        clicked => { root.page-changed(2); }
                                    }
                                }
                            }
                        }
                    }

                    if (root.has-level-filter || root.has-risk-filter || root.has-source-filter) : Rectangle {
                        min-width: 300px;
                        preferred-width: 420px;
                        horizontal-stretch: 2;
                        height: 34px;
                        border-radius: 10px;
                        background: #fbfcfe;
                        border-width: 1px;
                        border-color: #e7edf4;

                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 6px;

                            Text {
                                text: "Active";
                                color: #7e90a5;
                                font-size: 11px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }

                            if (root.has-level-filter) : ActiveFilterChip {
                                label: root.active-level-filter-text + " ×";
                                chip-background-color: #edf3ff;
                                chip-border-color: #bfd1ef;
                                chip-text-color: #466791;
                                clicked => { root.clear-level-filter(); }
                            }

                            if (root.has-risk-filter) : ActiveFilterChip {
                                label: root.active-risk-filter-text + " ×";
                                chip-background-color: #fbf3e4;
                                chip-border-color: #e6c98f;
                                chip-text-color: #8a6b21;
                                clicked => { root.clear-risk-filter(); }
                            }

                            if (root.has-source-filter) : ActiveFilterChip {
                                label: root.active-source-filter-text + " ×";
                                chip-background-color: #ebf7f1;
                                chip-border-color: #c2ddce;
                                chip-text-color: #4d755f;
                                clicked => { root.clear-source-filter(); }
                            }

                            Rectangle {
                                background: transparent;
                            }

                            InlineIconButton {
                                tool-icon: @image-url("icons/clear-filters.svg");
                                clicked => { root.clear-all-filters(); }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 1px;
                    border-radius: 1px;
                    background: #e8eef4;
                }

                HorizontalLayout {
                    spacing: 10px;

                    Rectangle {
                        min-width: 340px;
                        preferred-width: 380px;
                        horizontal-stretch: 11;
                        height: 44px;
                        border-radius: 10px;
                        background: #f8fbff;
                        border-width: 1px;
                        border-color: #dde6f3;

                        Rectangle {
                            x: 8px;
                            y: parent.height / 2 - 12px;
                            width: parent.width - 16px;
                            height: 24px;
                            background: transparent;

                            HorizontalLayout {
                                spacing: 6px;

                                Rectangle {
                                    width: 54px;
                                    height: 24px;
                                    background: transparent;

                                    Rectangle {
                                        x: 0px;
                                        y: 9px;
                                        width: 6px;
                                        height: 6px;
                                        border-radius: 3px;
                                        background: #6c96df;
                                    }

                                    Text {
                                        text: "Level";
                                        x: 12px;
                                        width: parent.width - 12px;
                                        height: parent.height;
                                        color: #5c77a0;
                                        font-size: 11px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                }

                                FilterPill {
                                    label: "All";
                                    width-scale: 1.22;
                                    idle-background: #edf3fb;
                                    idle-border: #edf3fb;
                                    idle-text: #5f7188;
                                    selected-background: #dfeafd;
                                    selected-border: #8eb2ef;
                                    selected-text: #1f5fd6;
                                    selected: root.active-level-filter == 0;
                                    clicked => { root.level-filter-clicked(0); }
                                }

                                FilterPill { label: "Info"; width-scale: 1.22; idle-background: #edf3fb; idle-border: #edf3fb; idle-text: #5f7188; selected-background: #dfeafd; selected-border: #8eb2ef; selected-text: #1f5fd6; selected: root.active-level-filter == 1; clicked => { root.level-filter-clicked(1); } }
                                FilterPill { label: "Warn"; width-scale: 1.22; idle-background: #edf3fb; idle-border: #edf3fb; idle-text: #5f7188; selected-background: #dfeafd; selected-border: #8eb2ef; selected-text: #1f5fd6; selected: root.active-level-filter == 2; clicked => { root.level-filter-clicked(2); } }
                                FilterPill { label: "Error"; width-scale: 1.22; idle-background: #edf3fb; idle-border: #edf3fb; idle-text: #5f7188; selected-background: #dfeafd; selected-border: #8eb2ef; selected-text: #1f5fd6; selected: root.active-level-filter == 3; clicked => { root.level-filter-clicked(3); } }
                            }
                        }
                    }

                    Rectangle {
                        min-width: 500px;
                        preferred-width: 560px;
                        horizontal-stretch: 15;
                        height: 44px;
                        border-radius: 10px;
                        background: #fffcf7;
                        border-width: 1px;
                        border-color: #ebdcc0;

                        Rectangle {
                            x: 8px;
                            y: parent.height / 2 - 12px;
                            width: parent.width - 16px;
                            height: 24px;
                            background: transparent;

                            HorizontalLayout {
                                spacing: 4px;

                                Rectangle {
                                    width: 76px;
                                    height: 24px;
                                    background: transparent;

                                    Rectangle {
                                        x: 0px;
                                        y: 9px;
                                        width: 6px;
                                        height: 6px;
                                        border-radius: 3px;
                                        background: #d49d3a;
                                    }

                                    Text {
                                        text: "Risk Tier";
                                        x: 12px;
                                        width: parent.width - 12px;
                                        height: parent.height;
                                        color: #946d22;
                                        font-size: 11px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                }

                                FilterPill { label: "All"; min-chip-width: 34px; width-scale: 1.0; idle-background: #fbf3e3; idle-border: #fbf3e3; idle-text: #8a6b21; selected-background: #ffe7bf; selected-border: #e3ae4e; selected-text: #9b5f00; selected: root.active-risk-filter == 0; clicked => { root.risk-filter-clicked(0); } }
                                FilterPill { label: "1"; min-chip-width: 24px; width-scale: 1.0; idle-background: #f5f7fa; idle-border: #f5f7fa; idle-text: #76879c; selected-background: #e6edf5; selected-border: #95a7bc; selected-text: #475569; selected: root.active-risk-filter == 1; clicked => { root.risk-filter-clicked(1); } }
                                FilterPill { label: "2"; min-chip-width: 24px; width-scale: 1.0; idle-background: #f1f6f2; idle-border: #f1f6f2; idle-text: #648f80; selected-background: #e8f1ec; selected-border: #7fa796; selected-text: #476d61; selected: root.active-risk-filter == 2; clicked => { root.risk-filter-clicked(2); } }
                                FilterPill { label: "3"; min-chip-width: 24px; width-scale: 1.0; idle-background: #f0f6ef; idle-border: #f0f6ef; idle-text: #5f8f57; selected-background: #e8f2e4; selected-border: #78a06f; selected-text: #4f7049; selected: root.active-risk-filter == 3; clicked => { root.risk-filter-clicked(3); } }
                                FilterPill { label: "4"; min-chip-width: 24px; width-scale: 1.0; idle-background: #f8f7ee; idle-border: #f8f7ee; idle-text: #7b8d39; selected-background: #f0edd6; selected-border: #a0a553; selected-text: #687422; selected: root.active-risk-filter == 4; clicked => { root.risk-filter-clicked(4); } }
                                FilterPill { label: "5"; min-chip-width: 24px; width-scale: 1.0; idle-background: #faf6eb; idle-border: #faf6eb; idle-text: #9b8a16; selected-background: #f3eccb; selected-border: #c0aa3f; selected-text: #806f04; selected: root.active-risk-filter == 5; clicked => { root.risk-filter-clicked(5); } }
                                FilterPill { label: "6"; min-chip-width: 24px; width-scale: 1.0; idle-background: #fbf5ea; idle-border: #fbf5ea; idle-text: #bf8d0a; selected-background: #f5ead0; selected-border: #d0a63f; selected-text: #946f00; selected: root.active-risk-filter == 6; clicked => { root.risk-filter-clicked(6); } }
                                FilterPill { label: "7"; min-chip-width: 24px; width-scale: 1.0; idle-background: #fcf3ec; idle-border: #fcf3ec; idle-text: #d97706; selected-background: #f8e6d4; selected-border: #d97706; selected-text: #9a5a00; selected: root.active-risk-filter == 7; clicked => { root.risk-filter-clicked(7); } }
                                FilterPill { label: "8"; min-chip-width: 24px; width-scale: 1.0; idle-background: #fbf0ea; idle-border: #fbf0ea; idle-text: #cb5c16; selected-background: #f7e1d6; selected-border: #cb5c16; selected-text: #94400d; selected: root.active-risk-filter == 8; clicked => { root.risk-filter-clicked(8); } }
                                FilterPill { label: "9"; min-chip-width: 24px; width-scale: 1.0; idle-background: #fbefef; idle-border: #fbefef; idle-text: #dc2626; selected-background: #f8dddd; selected-border: #dc2626; selected-text: #991b1b; selected: root.active-risk-filter == 9; clicked => { root.risk-filter-clicked(9); } }
                                FilterPill { label: "10"; min-chip-width: 30px; width-scale: 1.0; idle-background: #f8eded; idle-border: #f8eded; idle-text: #991b1b; selected-background: #f3d6d6; selected-border: #991b1b; selected-text: #7f1d1d; selected: root.active-risk-filter == 10; clicked => { root.risk-filter-clicked(10); } }
                            }
                        }
                    }

                    Rectangle {
                        min-width: 320px;
                        preferred-width: 360px;
                        horizontal-stretch: 10;
                        height: 44px;
                        border-radius: 10px;
                        background: #f7fbf8;
                        border-width: 1px;
                        border-color: #d8e8df;

                        Rectangle {
                            x: 8px;
                            y: parent.height / 2 - 12px;
                            width: parent.width - 16px;
                            height: 24px;
                            background: transparent;

                            HorizontalLayout {
                                spacing: 6px;

                                Rectangle {
                                    width: 62px;
                                    height: 24px;
                                    background: transparent;

                                    Rectangle {
                                        x: 0px;
                                        y: 9px;
                                        width: 6px;
                                        height: 6px;
                                        border-radius: 3px;
                                        background: #61a27c;
                                    }

                                    Text {
                                        text: "Source";
                                        x: 12px;
                                        width: parent.width - 12px;
                                        height: parent.height;
                                        color: #4d755f;
                                        font-size: 11px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                }

                                FilterPill { label: "All"; width-scale: 1.18; idle-background: #edf6f0; idle-border: #edf6f0; idle-text: #4f7562; selected-background: #daf3e5; selected-border: #79c39e; selected-text: #23734f; selected: root.active-source-filter == 0; clicked => { root.source-filter-clicked(0); } }
                                FilterPill { label: "Demo"; width-scale: 1.18; idle-background: #edf6f0; idle-border: #edf6f0; idle-text: #4f7562; selected-background: #daf3e5; selected-border: #79c39e; selected-text: #23734f; selected: root.active-source-filter == 1; clicked => { root.source-filter-clicked(1); } }
                                FilterPill { label: "Wparse"; width-scale: 1.18; idle-background: #edf6f0; idle-border: #edf6f0; idle-text: #4f7562; selected-background: #daf3e5; selected-border: #79c39e; selected-text: #23734f; selected: root.active-source-filter == 2; clicked => { root.source-filter-clicked(2); } }
                                FilterPill { label: "Wfusion"; width-scale: 1.18; idle-background: #edf6f0; idle-border: #edf6f0; idle-text: #4f7562; selected-background: #daf3e5; selected-border: #79c39e; selected-text: #23734f; selected: root.active-source-filter == 3; clicked => { root.source-filter-clicked(3); } }
                            }
                        }
                    }
                }
            }
        }
    }
}
