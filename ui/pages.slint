import { DetailRow, LaneLabel, LogTableView, TimeTick, TimelinePoint, TimelineToolButton, AlertTableView } from "base_components.slint";

export component OverviewPage inherits Rectangle {
    in property <[LaneLabel]> lane-labels: [];
    in property <[TimelinePoint]> timeline-points: [];
    in property <[TimeTick]> time-ticks: [];
    in property <float> first-event-x-pct: 0.0;
    in property <float> last-event-x-pct: 1.0;
    in property <int> hovered-point-index: -1;
    in property <int> selected-point-index: -1;
    in property <int> timeline-content-px: 1400;
    in-out property <length> timeline-canvas-x: -600px;
    in-out property <float> timeline-zoom: 1.0;
    in property <string> hover-detail-text: "Hover a point to preview.";
    in property <string> point-detail-summary: "";
    in property <[DetailRow]> point-detail-rows: [];
    in property <string> lane-legend-text: "";
    in property <string> top-targets-text: "";
    in property <string> source-text: "";
    in property <string> status-text: "";
    private property <length> hovered-point-anchor-x: 0px;
    private property <length> hovered-point-anchor-y: 0px;
    callback clear-all-filters();
    callback point-clicked(int);
    callback point-hovered(int);
    callback point-unhovered();

    VerticalLayout {
        vertical-stretch: 1;
        spacing: 10px;

        timeline-panel := Rectangle {
            property <length> timeline_pan_step: 30px;
            property <float> timeline_zoom_min: 0.5;
            property <float> timeline_zoom_max: 6.0;
            property <float> timeline_zoom_step: 0.25;
            property <float> timeline_zoom_in_value: min(self.timeline_zoom_max, root.timeline_zoom + self.timeline_zoom_step);
            property <float> timeline_zoom_out_value: max(self.timeline_zoom_min, root.timeline_zoom - self.timeline_zoom_step);
            property <length> timeline_min_canvas_x: min(0px, timeline-viewport.width - timeline-content.width);
            property <length> header_height: 42px;
            property <length> plot_box_height: max(250px, self.height - self.header_height - 12px);
            property <length> plot_grid_height: max(220px, self.plot_box_height - 24px);
            property <length> plot_left_inset: 30px;
            property <length> plot_right_inset: 30px;
            property <length> plot_top_inset: 24px;
            property <length> plot_bottom_inset: 48px;
            property <length> lane_rail_width: 74px;
            property <length> lane_band_height: max(30px, (self.plot_box_height - self.plot_top_inset - self.plot_bottom_inset) / max(1, lane-labels.length) - 6px);
            border-radius: 10px;
            background: #ffffff;
            vertical-stretch: 3;
            min-height: 360px;
            border-width: 0px;

            Text {
                text: "TimeLine";
                color: #31445d;
                font-size: 14px;
                font-weight: 600;
                x: 12px;
                y: 10px;
            }

            Rectangle {
                x: parent.width - self.width - 12px;
                y: 8px;
                width: 172px;
                height: 28px;
                border-radius: 8px;
                background: #f8fafc;
                border-width: 1px;
                border-color: #e2e8f0;

                HorizontalLayout {
                    padding-left: 4px;
                    padding-right: 4px;
                    spacing: 2px;

                    TimelineToolButton {
                        tool-icon: @image-url("icons/timeline-zoom-out.svg");
                        clicked => {
                            root.timeline_canvas_x = min(
                                0px,
                                timeline-viewport.width / 2 - (timeline-viewport.width / 2 - timeline-content.x) * timeline-panel.timeline_zoom_out_value / root.timeline_zoom
                            );
                            root.timeline_zoom = timeline-panel.timeline_zoom_out_value;
                        }
                    }

                    TimelineToolButton {
                        tool-icon: @image-url("icons/timeline-zoom-in.svg");
                        clicked => {
                            root.timeline_canvas_x = min(
                                0px,
                                timeline-viewport.width / 2 - (timeline-viewport.width / 2 - timeline-content.x) * timeline-panel.timeline_zoom_in_value / root.timeline_zoom
                            );
                            root.timeline_zoom = timeline-panel.timeline_zoom_in_value;
                        }
                    }

                    TimelineToolButton {
                        tool-icon: @image-url("icons/timeline-fit.svg");
                        clicked => {
                            root.timeline_canvas_x = min(
                                0px,
                                timeline-viewport.width / 2 - (timeline-viewport.width / 2 - timeline-content.x) * 1.0 / root.timeline_zoom
                            );
                            root.timeline_zoom = 1.0;
                        }
                    }

                    TimelineToolButton {
                        tool-icon: @image-url("icons/timeline-pan-left.svg");
                        clicked => {
                            root.timeline_canvas_x = min(0px, timeline-content.x + timeline-panel.timeline_pan_step);
                        }
                    }

                    TimelineToolButton {
                        tool-icon: @image-url("icons/timeline-pan-right.svg");
                        clicked => {
                            root.timeline_canvas_x = max(timeline-panel.timeline_min_canvas_x, timeline-content.x - timeline-panel.timeline_pan_step);
                        }
                    }

                    TimelineToolButton {
                        tool-icon: @image-url("icons/timeline-reset.svg");
                        clicked => {
                            root.timeline_canvas_x = 0px;
                            root.timeline_zoom = 1.0;
                            root.clear-all-filters();
                        }
                    }
                }
            }

            Rectangle {
                x: 12px;
                y: timeline-panel.header_height;
                width: parent.width - 24px;
                height: timeline-panel.plot_box_height;
                border-radius: 14px;
                background: #f8fafc;
                border-width: 1px;
                border-color: #e2e8f0;

                Rectangle {
                    x: 0px;
                    y: 0px;
                    width: timeline-panel.lane_rail_width;
                    height: parent.height;
                    border-radius: 14px;
                    background: #f8fafc;
                    border-width: 0px;

                    Text {
                        text: "Entities";
                        x: 12px;
                        y: 12px;
                        width: parent.width - 24px;
                        color: #8a99ab;
                        font-size: 9px;
                        font-weight: 600;
                        horizontal-alignment: left;
                    }

                    for lane in lane-labels: Rectangle {
                        x: 6px;
                        y: timeline-panel.plot_top_inset + max(0px, parent.height - timeline-panel.plot_top_inset - timeline-panel.plot_bottom_inset) * lane.y_pct - timeline-panel.lane_band_height / 2;
                        width: parent.width - 12px;
                        height: timeline-panel.lane_band_height;
                        border-radius: timeline-panel.lane_band_height / 2;
                        background: transparent;
                        border-width: 0px;

                        Rectangle {
                            x: 8px;
                            y: parent.height / 2 - 4px;
                            width: 6px;
                            height: 6px;
                            border-radius: 3px;
                            background: #a2afbf;
                        }

                        Text {
                            text: lane.label;
                            x: 20px;
                            y: 0px;
                            width: parent.width - 30px;
                            height: parent.height;
                            color: #57708e;
                            font-size: 8px;
                            font-weight: 500;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                        }
                    }
                }

                timeline-viewport := Rectangle {
                    x: timeline-panel.lane_rail_width + 12px;
                    y: 14px;
                    width: parent.width - timeline-panel.lane_rail_width - 28px;
                    height: parent.height - 28px;
                    clip: true;
                    background: transparent;

                    TouchArea {
                        property <length> start_canvas_x: 0px;
                        x: 0px;
                        y: 0px;
                        width: parent.width;
                        height: timeline-panel.plot_grid_height;

                        pointer-event(event) => {
                            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                self.start_canvas_x = timeline-content.x;
                            }
                        }

                        moved => {
                            if (self.enabled && self.pressed) {
                                root.timeline_canvas_x = self.start_canvas_x + (self.mouse-x - self.pressed-x);
                            }
                        }
                    }

                    timeline-content := Rectangle {
                        x: max(min(0px, timeline-viewport.width - self.width), min(0px, root.timeline_canvas_x));
                        y: 0px;
                        width: max(parent.width - 6px, root.timeline_content_px * 1px * root.timeline_zoom);
                        height: parent.height;
                        background: transparent;

                        Rectangle {
                            x: 0px;
                            y: 0px;
                            width: parent.width;
                            height: timeline-panel.plot_grid_height;
                            border-radius: 12px;
                            background: #f8fafc;
                            border-width: 1px;
                            border-color: #e2e8f0;

                            for lane[i] in lane-labels: Rectangle {
                                x: timeline-panel.plot_left_inset;
                                y: timeline-panel.plot_top_inset + max(0px, parent.height - timeline-panel.plot_top_inset - timeline-panel.plot_bottom_inset) * lane.y_pct - timeline-panel.lane_band_height / 2;
                                width: parent.width - timeline-panel.plot_left_inset - timeline-panel.plot_right_inset;
                                height: timeline-panel.lane_band_height;
                                border-radius: timeline-panel.lane_band_height / 2;
                                background: transparent;
                                border-width: 0px;
                            }

                            for tick in time-ticks: Rectangle {
                                x: timeline-panel.plot_left_inset + max(0px, parent.width - timeline-panel.plot_left_inset - timeline-panel.plot_right_inset) * tick.x_pct;
                                y: timeline-panel.plot_top_inset - 8px;
                                width: 1px;
                                height: max(24px, parent.height - timeline-panel.plot_top_inset - timeline-panel.plot_bottom_inset + 16px);
                                background: #e8edf3;
                            }

                            Rectangle {
                                x: timeline-panel.plot_left_inset + max(0px, parent.width - timeline-panel.plot_left_inset - timeline-panel.plot_right_inset) * root.first-event-x-pct;
                                y: timeline-panel.plot_top_inset - 8px;
                                width: 2px;
                                height: max(24px, parent.height - timeline-panel.plot_top_inset - timeline-panel.plot_bottom_inset + 16px);
                                background: #9fb0c5;
                            }

                            Rectangle {
                                x: timeline-panel.plot_left_inset + max(0px, parent.width - timeline-panel.plot_left_inset - timeline-panel.plot_right_inset) * root.last-event-x-pct - 2px;
                                y: timeline-panel.plot_top_inset - 8px;
                                width: 2px;
                                height: max(24px, parent.height - timeline-panel.plot_top_inset - timeline-panel.plot_bottom_inset + 16px);
                                background: #9fb0c5;
                            }

                            for lane in lane-labels: Rectangle {
                                x: timeline-panel.plot_left_inset + 6px;
                                y: timeline-panel.plot_top_inset + max(0px, parent.height - timeline-panel.plot_top_inset - timeline-panel.plot_bottom_inset) * lane.y_pct;
                                width: parent.width - timeline-panel.plot_left_inset - timeline-panel.plot_right_inset - 12px;
                                height: 2px;
                                border-radius: 1px;
                                background: #e3e8ef;
                            }

                            for point[i] in timeline-points: Rectangle {
                                private property <color> tone-core: point.risk_tier >= 9 ? #991b1b
                                    : (point.risk_tier == 8 ? #dc2626
                                    : (point.risk_tier == 7 ? #c2410c
                                    : (point.risk_tier == 6 ? #d97706
                                    : (point.risk_tier == 5 ? #c99700
                                    : (point.risk_tier == 4 ? #a3a300
                                    : (point.risk_tier == 3 ? #6f9a2b
                                    : (point.risk_tier == 2 ? #5f8f57
                                    : (point.risk_tier == 1 ? #6d8f84 : #7f9b91))))))));
                                private property <color> tone-selected: #475569;
                                width: 11px + point.size_norm * 12px;
                                height: 11px + point.size_norm * 12px;
                                x: timeline-panel.plot_left_inset + max(0px, parent.width - timeline-panel.plot_left_inset - timeline-panel.plot_right_inset) * point.x_pct - self.width / 2;
                                y: timeline-panel.plot_top_inset + max(0px, parent.height - timeline-panel.plot_top_inset - timeline-panel.plot_bottom_inset) * point.y_pct - self.height / 2;
                                border-radius: self.width / 2;
                                background: self.tone-core;
                                border-width: 0px;
                                border-color: transparent;

                                Rectangle {
                                    visible: i == root.selected-point-index;
                                    x: -4px;
                                    y: -4px;
                                    width: parent.width + 8px;
                                    height: parent.height + 8px;
                                    border-radius: self.width / 2;
                                    background: transparent;
                                    border-width: 1px;
                                    border-color: parent.tone-selected;
                                }

                                point-hover := TouchArea {
                                    property <length> start_canvas_x: 0px;
                                    property <bool> dragged: false;

                                    pointer-event(event) => {
                                        if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                            self.start_canvas_x = timeline-content.x;
                                            self.dragged = false;
                                        }
                                    }

                                    moved => {
                                        if (self.enabled && self.pressed) {
                                            if (self.mouse-x > self.pressed-x + 3px || self.mouse-x < self.pressed-x - 3px) {
                                                self.dragged = true;
                                            }
                                        }
                                    }

                                    clicked => {
                                        if (!self.dragged) {
                                            root.point-clicked(i);
                                        }
                                    }

                                    changed has-hover => {
                                        if self.has-hover {
                                            root.hovered-point-anchor-x = parent.x + parent.width / 2;
                                            root.hovered-point-anchor-y = parent.y + parent.height / 2;
                                            root.point-hovered(i);
                                        } else {
                                            root.point-unhovered();
                                        }
                                    }
                                }
                            }

                            hover-overlay := Rectangle {
                                visible: hovered-point-index >= 0 && hovered-point-index < timeline-points.length;
                                property <length> overlay-width: 320px;
                                property <length> overlay-height: 98px;
                                property <length> overlay-gap: 14px;
                                property <length> overlay-min-x: 12px;
                                property <length> overlay-max-x: parent.width - self.overlay-width - 12px;
                                property <length> overlay-min-y: 8px;
                                property <length> overlay-max-y: parent.height - timeline-panel.plot_bottom_inset - self.overlay-height - 8px;
                                property <bool> prefer-right: root.hovered-point-anchor-x <= parent.width / 2;
                                property <bool> prefer-below: root.hovered-point-anchor-y <= (parent.height - timeline-panel.plot_bottom_inset) / 2;
                                property <bool> can-place-right: root.hovered-point-anchor-x + self.overlay-gap + self.overlay-width <= parent.width - 12px;
                                property <bool> can-place-left: root.hovered-point-anchor-x - self.overlay-gap - self.overlay-width >= 12px;
                                property <bool> can-place-above: root.hovered-point-anchor-y - self.overlay-gap - self.overlay-height >= self.overlay-min-y;
                                property <bool> can-place-below: root.hovered-point-anchor-y + self.overlay-gap + self.overlay-height <= parent.height - timeline-panel.plot_bottom_inset - 8px;
                                x: min(
                                    self.overlay-max-x,
                                    max(
                                        self.overlay-min-x,
                                        self.prefer-right && self.can-place-right
                                            ? root.hovered-point-anchor-x + self.overlay-gap
                                            : (!self.prefer-right && self.can-place-left
                                                ? root.hovered-point-anchor-x - self.overlay-gap - self.overlay-width
                                                : (self.can-place-left
                                                    ? root.hovered-point-anchor-x - self.overlay-gap - self.overlay-width
                                                    : (self.can-place-right
                                                        ? root.hovered-point-anchor-x + self.overlay-gap
                                                        : root.hovered-point-anchor-x - self.overlay-width / 2)))
                                    )
                                );
                                y: min(
                                    self.overlay-max-y,
                                    max(
                                        self.overlay-min-y,
                                        self.prefer-below && self.can-place-below
                                            ? root.hovered-point-anchor-y + self.overlay-gap
                                            : (!self.prefer-below && self.can-place-above
                                                ? root.hovered-point-anchor-y - self.overlay-gap - self.overlay-height
                                                : (self.can-place-above
                                                    ? root.hovered-point-anchor-y - self.overlay-gap - self.overlay-height
                                                    : (self.can-place-below
                                                        ? root.hovered-point-anchor-y + self.overlay-gap
                                                        : root.hovered-point-anchor-y - self.overlay-height / 2)))
                                    )
                                );
                                width: self.overlay-width;
                                height: self.overlay-height;
                                border-radius: 10px;
                                background: #fffdf5;
                                border-width: 1px;
                                border-color: #dfc58e;
                                drop-shadow-blur: 12px;
                                drop-shadow-color: #ccb88944;
                                drop-shadow-offset-y: 2px;

                                Text {
                                    text: hover-detail-text;
                                    color: #4b5563;
                                    x: 12px;
                                    y: 10px;
                                    width: parent.width - 24px;
                                    font-size: 12px;
                                    font-weight: 600;
                                    wrap: word-wrap;
                                    horizontal-alignment: left;
                                    vertical-alignment: top;
                                }
                            }

                            Rectangle {
                                x: 0px;
                                y: parent.height - timeline-panel.plot_bottom_inset;
                                width: parent.width;
                                height: timeline-panel.plot_bottom_inset;
                                background: transparent;
                                border-width: 0px;
                            }
                        }

                        Rectangle {
                            x: 0px;
                            y: timeline-panel.plot_grid_height - timeline-panel.plot_bottom_inset + 10px;
                            width: parent.width;
                            height: 1px;
                            border-radius: 0px;
                            background: #d7dee7;
                        }

                        for tick in time-ticks: Rectangle {
                            x: timeline-panel.plot_left_inset + max(0px, parent.width - timeline-panel.plot_left_inset - timeline-panel.plot_right_inset) * tick.x_pct - 28px;
                            y: parent.height - 24px;
                            width: 56px;
                            height: 18px;
                            border-radius: 0px;
                            background: transparent;
                            border-width: 0px;
                            border-color: transparent;

                            Text {
                                text: tick.label;
                                color: #8e9bae;
                                width: parent.width;
                                height: parent.height;
                                font-size: 9px;
                                font-weight: 500;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            x: timeline-panel.plot_left_inset + max(0px, parent.width - timeline-panel.plot_left_inset - timeline-panel.plot_right_inset) * root.first-event-x-pct - 24px;
                            y: parent.height - 42px;
                            width: 48px;
                            height: 16px;
                            background: transparent;

                            Text {
                                text: "Start";
                                color: #6d7f95;
                                width: parent.width;
                                height: parent.height;
                                font-size: 9px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            x: timeline-panel.plot_left_inset + max(0px, parent.width - timeline-panel.plot_left_inset - timeline-panel.plot_right_inset) * root.last-event-x-pct - 24px;
                            y: parent.height - 42px;
                            width: 48px;
                            height: 16px;
                            background: transparent;

                            Text {
                                text: "End";
                                color: #6d7f95;
                                width: parent.width;
                                height: parent.height;
                                font-size: 9px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        LogTableView {
            vertical-stretch: 2;
            min-height: root.point-detail-rows.length > 0 ? 260px : 116px;
            title: "Selection Detail";
            show-pagination: false;
            summary: root.point-detail-summary;
            show-summary: false;
            rows: root.point-detail-rows;
            compact-when-empty: true;
            table-width: 1280px;
            body-viewport-height: root.point-detail-rows.length > 0 ? 252px : 56px;
        }
    }
}

export component LogDataPage inherits Rectangle {
    in property <string> summary: "";
    in property <[DetailRow]> rows: [];
    in property <string> pagination-text: "";
    in property <bool> has-prev-page: false;
    in property <bool> has-next-page: false;
    in property <int> reset-token: 0;
    out property <length> table-body-visible-height: log-table.body-visible-height;
    callback prev-page();
    callback next-page();

    VerticalLayout {
        vertical-stretch: 1;
        spacing: 10px;

        log-table := LogTableView {
            summary: root.summary;
            rows: root.rows;
            pagination-text: root.pagination-text;
            has-prev-page: root.has-prev-page;
            has-next-page: root.has-next-page;
            reset-token: root.reset-token;
            prev-page => {
                root.prev-page();
            }
            next-page => {
                root.next-page();
            }
        }
    }
}

export component AlertDataPage inherits Rectangle {
    in property <string> summary: "";
    in property <[DetailRow]> rows: [];
    in property <string> pagination-text: "";
    in property <bool> has-prev-page: false;
    in property <bool> has-next-page: false;
    in property <int> reset-token: 0;
    out property <length> table-body-visible-height: alert-table.body-visible-height;
    callback prev-page();
    callback next-page();

    VerticalLayout {
        vertical-stretch: 1;
        spacing: 10px;

        alert-table := AlertTableView {
            summary: root.summary;
            rows: root.rows;
            pagination-text: root.pagination-text;
            has-prev-page: root.has-prev-page;
            has-next-page: root.has-next-page;
            reset-token: root.reset-token;
            prev-page => {
                root.prev-page();
            }
            next-page => {
                root.next-page();
            }
        }
    }
}
