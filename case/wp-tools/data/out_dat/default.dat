{ wp_event_id: 2548918565890984969 id: "7e47c18d" message/content[0]/text: "Usage: openclaw [options] [command]\n  dashboard            Open the Control UI with your current token\n  devices *            Device pairing + token management\n  models *             Discover, scan, and configure models\n  openclaw models --help\n    Show detailed help for the models command." message/content[0]/type: "text" message/details/aggregated: "Usage: openclaw [options] [command]\n  dashboard            Open the Control UI with your current token\n  devices *            Device pairing + token management\n  models *             Discover, scan, and configure models\n  openclaw models --help\n    Show detailed help for the models command." message/details/cwd: "/Users/zuowenjian/.openclaw/workspace" message/details/durationMs: 2071 message/details/exitCode: 0 message/details/status: "completed" message/isError: false message/role: "toolResult" message/timestamp: 1773799754541 message/toolCallId: "tool_oh9ZuVaMJJUKgvHxJAWPHWWq" message/toolName: "exec" parentId: "7e41e03b" timestamp: "2026-03-18T02:09:14.541Z" type: "message" wp_src_key: "file_1" access_source: "../openclaw/target_data/raw_log.dat" }
