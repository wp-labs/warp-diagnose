{ wp_event_id: 2548918565890984977 id: "47631d3b" message/content[0]/text: "🦞 OpenClaw 2026.3.13 (61d171a) — I'll butter your workflow like a lobster roll: messy, delicious, effective.\n\nUsage: openclaw acp [options] [command]\n\nRun an ACP bridge backed by the Gateway\n\nOptions:\n  -h, --help               Display help for command\n  --no-prefix-cwd          Do not prefix prompts with the working directory\n  --password <password>    Gateway password (if required)\n  --password-file <path>   Read gateway password from file\n  --provenance <mode>      ACP provenance mode: off, meta, or meta+receipt\n  --require-existing       Fail if the session key/label does not exist\n                           (default: false)\n  --reset-session          Reset the session key before first use (default:\n                           false)\n  --session <key>          Default session key (e.g. agent:main:main)\n  --session-label <label>  Default session label to resolve\n  --token <token>          Gateway token (if required)\n  --token-file <path>      Read gateway token from file\n  --url <url>              Gateway WebSocket URL (defaults to gateway.remote.url\n                           when configured)\n  -v, --verbose            Verbose logging to stderr (default: false)\n\nCommands:\n  client                   Run an interactive ACP client against the local ACP\n                           bridge\n\nDocs: https://docs.openclaw.ai/cli/acp" message/content[0]/type: "text" message/details/aggregated: "🦞 OpenClaw 2026.3.13 (61d171a) — I'll butter your workflow like a lobster roll: messy, delicious, effective.\n\nUsage: openclaw acp [options] [command]\n\nRun an ACP bridge backed by the Gateway\n\nOptions:\n  -h, --help               Display help for command\n  --no-prefix-cwd          Do not prefix prompts with the working directory\n  --password <password>    Gateway password (if required)\n  --password-file <path>   Read gateway password from file\n  --provenance <mode>      ACP provenance mode: off, meta, or meta+receipt\n  --require-existing       Fail if the session key/label does not exist\n                           (default: false)\n  --reset-session          Reset the session key before first use (default:\n                           false)\n  --session <key>          Default session key (e.g. agent:main:main)\n  --session-label <label>  Default session label to resolve\n  --token <token>          Gateway token (if required)\n  --token-file <path>      Read gateway token from file\n  --url <url>              Gateway WebSocket URL (defaults to gateway.remote.url\n                           when configured)\n  -v, --verbose            Verbose logging to stderr (default: false)\n\nCommands:\n  client                   Run an interactive ACP client against the local ACP\n                           bridge\n\nDocs: https://docs.openclaw.ai/cli/acp" message/details/cwd: "/Users/zuowenjian/.openclaw/workspace" message/details/durationMs: 753 message/details/exitCode: 0 message/details/status: "completed" message/isError: false message/role: "toolResult" message/timestamp: 1773799770811 message/toolCallId: "tool_QCp2H6NGBzfLugmMnAyhqG7i" message/toolName: "exec" parentId: "3f192895" timestamp: "2026-03-18T02:09:30.812Z" type: "message" wp_src_key: "file_1" access_source: "../openclaw/target_data/raw_log.dat" }
